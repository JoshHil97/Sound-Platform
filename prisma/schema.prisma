generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TRAINEE
  SOUND_OPERATOR
  ENGINEER
  SENIOR_ENGINEER
  TECHNICAL_DIRECTOR
  ADMIN
}

enum CurriculumLevel {
  FOUNDATIONS
  OPERATOR
  ENGINEER
  SENIOR_ENGINEER
  TECHNICAL_DIRECTOR
}

enum LessonDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum AttemptStatus {
  ASSIGNED
  IN_PROGRESS
  NEEDS_MENTOR_REVIEW
  APPROVED
  RETRY_REQUIRED
}

enum EquipmentCategory {
  MIXER
  STAGE_BOX
  MICROPHONE
  WIRELESS_SYSTEM
  SPEAKER
  MONITOR
  P16_SYSTEM
  DANTE_DEVICE
  COMPUTER
  SOFTWARE
  NETWORK_SWITCH
  CABLE
  ACCESSORY
}

enum VisualCategory {
  EQUIPMENT_PHOTO
  CONSOLE_SCREENSHOT
  SOFTWARE_SCREENSHOT
  PLUGIN_EXAMPLE
  SIGNAL_DIAGRAM
  TRAINING_EXAMPLE
}

enum VisualRights {
  OFFICIAL_VENDOR_REFERENCE
  CHURCH_OWNED_REQUIRED
  CREATE_ORIGINAL_DIAGRAM
  PERMISSION_REQUIRED
}

enum AudioExampleCategory {
  GAIN
  EQ
  DYNAMICS
  FEEDBACK
  LIVESTREAM
}

enum VideoReviewStatus {
  CONFIRMED_SOURCE
  NEEDS_FINAL_VIDEO_SELECTION
}

enum CurriculumStatus {
  DRAFT
  ACTIVE
  RETIRED
}

enum CompetencyCategory {
  KNOWLEDGE
  PRACTICAL
  OPERATIONAL
  TROUBLESHOOTING
  COMMUNICATION
  LEADERSHIP
}

enum SkillDomain {
  X32
  DANTE
  LOGIC
  WAVES
  WIRELESS
  P16
  FOH
  LIVESTREAM
  TROUBLESHOOTING
  LEADERSHIP
}

enum LessonType {
  CONCEPT
  WALKTHROUGH
  SIMULATOR
  LISTENING_DRILL
  SERVICE_DRILL
  SCENARIO
  MENTOR_ASSESSMENT
}

enum CurriculumAssessmentType {
  KNOWLEDGE
  PRACTICAL
  SCENARIO
  SERVICE
  MENTOR
  CERTIFICATION
}

enum EvidenceType {
  QUIZ
  SOUND_LAB
  PRACTICAL
  SERVICE_OBSERVATION
  MENTOR_NOTE
  MEDIA_UPLOAD
}

enum EvidenceStatus {
  SUBMITTED
  NEEDS_REVIEW
  APPROVED
  REVISION_REQUESTED
  REJECTED
}

enum ReviewDecision {
  APPROVED
  REVISION_REQUESTED
  REJECTED
}

model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  role               UserRole            @default(TRAINEE)
  quizAttempts       QuizAttempt[]
  assessmentAttempts AssessmentAttempt[]
  certifications     Certification[]
  mentorSignOffs     MentorSignOff[]     @relation("MentorSignOffTrainee")
  mentorReviews      MentorSignOff[]     @relation("MentorSignOffMentor")
  serviceExperiences ServiceExperience[] @relation("ServiceExperienceTrainee")
  mentoredServices   ServiceExperience[] @relation("ServiceExperienceMentor")
  evidence           Evidence[]
  evidenceReviews    EvidenceReview[]    @relation("EvidenceReviewer")
  serviceLogs        ServiceLog[]
  incidents          Incident[]          @relation("IncidentReporter")
  comments           Comment[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Role {
  id          String   @id @default(cuid())
  name        UserRole @unique
  description String
}

model Module {
  id            String                @id @default(cuid())
  slug          String                @unique
  title         String
  academyId     String?
  academy       Academy?              @relation(fields: [academyId], references: [id])
  level         CurriculumLevel
  summary       String
  duration      String
  objectives    String
  prerequisites String?
  certification String
  order         Int
  lessons       Lesson[]
  assessments   PracticalAssessment[]
  competencies  Competency[]          @relation("ModuleCompetencies")
  certificationDefinitions CertificationDefinition[] @relation("CertificationModules")
  outcomes      LearningOutcome[]
  exercises     PracticalExercise[]
  curriculumAssessments CurriculumAssessment[]
  churchNotes   ChurchSpecificNote[]
}

model Lesson {
  id                       String              @id @default(cuid())
  slug                     String              @unique
  title                    String
  summary                  String
  difficulty               LessonDifficulty
  durationMinutes          Int
  moduleId                 String
  module                   Module              @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  beginnerExplanation      String
  intermediateExplanation  String
  advancedExplanation      String
  practicalExercise        String
  activeRecallPrompt       String
  spacedRepetitionPrompt   String
  mentorSignoffCriteria    String
  lessonType               LessonType?         @default(CONCEPT)
  ministryContext          String?
  lessonSteps              LessonStep[]
  learningOutcomes         LearningOutcome[]
  practicalExercises       PracticalExercise[]
  contentBlocks            LessonContent[]
  quizzes                  Quiz[]
  churchNotes              ChurchSpecificNote[]
}

model Academy {
  id                       String                    @id @default(cuid())
  slug                     String                    @unique
  title                    String
  mission                  String
  ownerRole                UserRole
  order                    Int
  activeVersion            String                    @default("1.0")
  modules                  Module[]
  certificationDefinitions CertificationDefinition[]
  competencies             Competency[]              @relation("AcademyCompetencies")
  learningOutcomes         LearningOutcome[]
  skillTrees               SkillTree[]
  progressionRulesFrom     ProgressionRule[]         @relation("ProgressionFromAcademy")
  progressionRulesTo       ProgressionRule[]         @relation("ProgressionToAcademy")
  status                   CurriculumStatus          @default(ACTIVE)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
}

model CertificationDefinition {
  id                          String                    @id @default(cuid())
  slug                        String                    @unique
  academyId                   String
  academy                     Academy                   @relation(fields: [academyId], references: [id], onDelete: Cascade)
  level                       CurriculumLevel
  title                       String
  mission                     String
  renewalMonths               Int
  requiredServiceObservations Int
  status                      CurriculumStatus          @default(ACTIVE)
  competencyRequirements      Competency[]              @relation("CertificationCompetencies")
  moduleRequirements          Module[]                  @relation("CertificationModules")
  assessmentRequirements      CurriculumAssessment[]    @relation("CertificationAssessments")
  progressionRulesFrom        ProgressionRule[]         @relation("ProgressionFromCertification")
  progressionRulesTo          ProgressionRule[]         @relation("ProgressionToCertification")
}

model Competency {
  id                       String                    @id @default(cuid())
  slug                     String                    @unique
  title                    String
  category                 CompetencyCategory
  description              String
  level                    CurriculumLevel
  academies                Academy[]                 @relation("AcademyCompetencies")
  modules                  Module[]                  @relation("ModuleCompetencies")
  skills                   Skill[]                   @relation("SkillCompetencies")
  assessments              CurriculumAssessment[]    @relation("AssessmentCompetencies")
  certificationDefinitions CertificationDefinition[] @relation("CertificationCompetencies")
  evidence                 Evidence[]
}

model Skill {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  domain      SkillDomain
  description String
  competencies Competency[] @relation("SkillCompetencies")
  treeNodes   SkillTreeNode[]
}

model SkillTree {
  id        String          @id @default(cuid())
  academyId String
  academy   Academy         @relation(fields: [academyId], references: [id], onDelete: Cascade)
  title     String
  version   String          @default("1.0")
  nodes     SkillTreeNode[]
}

model SkillTreeNode {
  id           String          @id @default(cuid())
  skillTreeId  String
  skillTree    SkillTree       @relation(fields: [skillTreeId], references: [id], onDelete: Cascade)
  skillId      String
  skill        Skill           @relation(fields: [skillId], references: [id])
  parentNodeId String?
  parentNode   SkillTreeNode?  @relation("SkillTreeParent", fields: [parentNodeId], references: [id])
  childNodes   SkillTreeNode[] @relation("SkillTreeParent")
  unlockRule   String
  positionX    Int
  positionY    Int
}

model LessonStep {
  id                  String  @id @default(cuid())
  lessonId            String
  lesson              Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  interfaceType       String
  action              String
  expectedObservation String
  whyItMatters        String
  safetyNote          String?
  order               Int
}

model LearningOutcome {
  id             String   @id @default(cuid())
  text           String
  outcomeType    String
  measurableVerb String
  academyId      String?
  academy        Academy? @relation(fields: [academyId], references: [id])
  moduleId       String?
  module         Module?  @relation(fields: [moduleId], references: [id])
  lessonId       String?
  lesson         Lesson?  @relation(fields: [lessonId], references: [id])
}

model PracticalExercise {
  id                String  @id @default(cuid())
  moduleId          String?
  module            Module? @relation(fields: [moduleId], references: [id])
  lessonId          String?
  lesson            Lesson? @relation(fields: [lessonId], references: [id])
  title             String
  setup             String
  task              String
  expectedResult    String
  evidenceRequired  String
  safetyConstraints String
}

model CurriculumAssessment {
  id                       String                    @id @default(cuid())
  slug                     String                    @unique
  moduleId                 String?
  module                   Module?                   @relation(fields: [moduleId], references: [id])
  type                     CurriculumAssessmentType
  title                    String
  rubric                   String
  passCriteria             String
  retryCriteria            String
  mentorRoleRequired       UserRole
  competencies             Competency[]              @relation("AssessmentCompetencies")
  certificationDefinitions CertificationDefinition[] @relation("CertificationAssessments")
  mentorSignOffs           MentorSignOff[]
  evidence                 Evidence[]
}

model MentorSignOff {
  id                  String               @id @default(cuid())
  traineeId           String
  trainee             User                 @relation("MentorSignOffTrainee", fields: [traineeId], references: [id])
  mentorId            String
  mentor              User                 @relation("MentorSignOffMentor", fields: [mentorId], references: [id])
  assessmentId         String
  assessment           CurriculumAssessment @relation(fields: [assessmentId], references: [id])
  status              AttemptStatus         @default(NEEDS_MENTOR_REVIEW)
  observedAt           DateTime?
  serviceContext       String
  feedback             String
  nextStep             String
}

model ServiceExperience {
  id                       String   @id @default(cuid())
  traineeId                String
  trainee                  User     @relation("ServiceExperienceTrainee", fields: [traineeId], references: [id])
  serviceDate              DateTime
  serviceType              String
  roleServed               String
  mentorId                 String?
  mentor                   User?    @relation("ServiceExperienceMentor", fields: [mentorId], references: [id])
  observationNotes          String
  approvedForCertification Boolean  @default(false)
}

model ProgressionRule {
  id                    String                   @id @default(cuid())
  fromAcademyId          String?
  fromAcademy            Academy?                 @relation("ProgressionFromAcademy", fields: [fromAcademyId], references: [id])
  toAcademyId            String?
  toAcademy              Academy?                 @relation("ProgressionToAcademy", fields: [toAcademyId], references: [id])
  fromCertificationId    String?
  fromCertification      CertificationDefinition? @relation("ProgressionFromCertification", fields: [fromCertificationId], references: [id])
  toCertificationId      String?
  toCertification        CertificationDefinition? @relation("ProgressionToCertification", fields: [toCertificationId], references: [id])
  ruleType               String
  requirement            String
  active                 Boolean                  @default(true)
}

model Evidence {
  id                String                @id @default(cuid())
  userId            String
  user              User                  @relation(fields: [userId], references: [id])
  type              EvidenceType
  title             String
  description       String
  assetUrl          String?
  relatedEntityType String
  relatedEntityId   String
  competencyId      String?
  competency        Competency?           @relation(fields: [competencyId], references: [id])
  assessmentId      String?
  assessment        CurriculumAssessment? @relation(fields: [assessmentId], references: [id])
  submittedAt       DateTime              @default(now())
  status            EvidenceStatus        @default(SUBMITTED)
  reviews           EvidenceReview[]
}

model EvidenceReview {
  id         String         @id @default(cuid())
  evidenceId String
  evidence   Evidence       @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   User           @relation("EvidenceReviewer", fields: [reviewerId], references: [id])
  decision   ReviewDecision
  notes      String
  reviewedAt DateTime       @default(now())
}

model LessonContent {
  id       String @id @default(cuid())
  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  heading  String
  body     String
  sort     Int
}

model Quiz {
  id        String        @id @default(cuid())
  title     String
  passScore Int
  lessonId  String
  lesson    Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  QuizAttempt[]
}

model Question {
  id        String @id @default(cuid())
  quizId    String
  quiz      Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  prompt    String
  options   String
  answer    String
  rationale String
}

model QuizAttempt {
  id        String   @id @default(cuid())
  quizId    String
  quiz      Quiz     @relation(fields: [quizId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  score     Int
  passed    Boolean
  evidence  String?
  createdAt DateTime @default(now())
}

model PracticalAssessment {
  id       String              @id @default(cuid())
  title    String
  rubric   String
  moduleId String
  module   Module              @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  attempts AssessmentAttempt[]
}

model AssessmentAttempt {
  id           String              @id @default(cuid())
  assessmentId String
  assessment   PracticalAssessment @relation(fields: [assessmentId], references: [id])
  userId       String
  user         User                @relation(fields: [userId], references: [id])
  status       AttemptStatus       @default(ASSIGNED)
  mentorName   String?
  evidence     String?
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model Certification {
  id                  String          @id @default(cuid())
  userId              String
  user                User            @relation(fields: [userId], references: [id])
  level               CurriculumLevel
  modulesCompleted    Int
  quizAverage         Int
  practicalSignoffs   Int
  serviceObservations Int
  status              AttemptStatus   @default(IN_PROGRESS)
  renewalDue          DateTime?
  seniorNotes         String?
}

model Equipment {
  id               String            @id @default(cuid())
  slug             String            @unique
  name             String
  category         EquipmentCategory
  model            String
  location         String
  purpose          String
  inputs           String
  outputs          String
  connectedDevices String
  commonIssues     String
  sopLinks         String
  photoPlaceholder String?
  notes            String
  lastUpdated      DateTime          @default(now())
}

model VisualAsset {
  id           String         @id @default(cuid())
  slug         String         @unique
  title        String
  category     VisualCategory
  trainingUse  String
  sourceName   String
  sourceUrl    String
  rights       VisualRights
  linkedTopics String
  notes        String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model LessonGuide {
  id               String   @id @default(cuid())
  lessonSlug       String   @unique
  coreIdea         String
  boardChecks      String
  listeningTargets String
  commonMistakes   String
  mentorPrompt     String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AudioExample {
  id            String               @id @default(cuid())
  slug          String               @unique
  title         String
  category      AudioExampleCategory
  whatYouHear   String
  boardSymptoms String
  checks        String
  linkedLessons String
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model TrainingVideo {
  id             String            @id @default(cuid())
  slug           String            @unique
  title          String
  topic          String
  sourceUrl      String
  sourceName     String
  durationTarget String
  whyUse         String
  linkedLessons  String
  reviewStatus   VideoReviewStatus
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model SOP {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  category  String
  purpose   String
  steps     String
  ownerRole UserRole
  version   Int      @default(1)
  updatedAt DateTime @updatedAt
}

model TroubleshootingFlow {
  id        String                @id @default(cuid())
  slug      String                @unique
  title     String
  symptom   String
  priority  String
  steps     TroubleshootingStep[]
  incidents Incident[]
}

model TroubleshootingStep {
  id         String              @id @default(cuid())
  flowId     String
  flow       TroubleshootingFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  key        String
  prompt     String
  helpText   String
  yesNextKey String?
  noNextKey  String?
  resolution String?
  sort       Int
}

model SignalPath {
  id          String @id @default(cuid())
  title       String
  source      String
  path        String
  destination String
  notes       String
}

model ServiceChecklist {
  id          String   @id @default(cuid())
  title       String
  serviceType String
  steps       String
  ownerRole   UserRole
}

model ServiceLog {
  id          String     @id @default(cuid())
  serviceDate DateTime
  serviceType String
  operatorId  String
  operator    User       @relation(fields: [operatorId], references: [id])
  notes       String
  incidents   Incident[]
}

model Incident {
  id           String               @id @default(cuid())
  title        String
  severity     String
  status       String
  description  String
  resolution   String?
  reporterId   String
  reporter     User                 @relation("IncidentReporter", fields: [reporterId], references: [id])
  serviceLogId String?
  serviceLog   ServiceLog?          @relation(fields: [serviceLogId], references: [id])
  flowId       String?
  flow         TroubleshootingFlow? @relation(fields: [flowId], references: [id])
  createdAt    DateTime             @default(now())
}

model Comment {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  targetType String
  targetId   String
  body       String
  createdAt  DateTime @default(now())
}

model ChurchSpecificNote {
  id        String   @id @default(cuid())
  moduleId  String?
  module    Module?  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  lessonId  String?
  lesson    Lesson?  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title     String
  body      String
  updatedAt DateTime @updatedAt
}
